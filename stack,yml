version: '3.8'

services:
app-reloj:
image: ghcr.io/victor1997h/app-reloj:latest

```
networks:
  - traefik-public

deploy:
  replicas: 1

  update_config:
    parallelism: 1
    delay: 10s

  restart_policy:
    condition: on-failure

  labels:
    - "traefik.enable=true"
    - "traefik.http.routers.app-reloj.entrypoints=http"
    - "traefik.http.routers.app-reloj.rule=Host(`reloj.byronrm.com`)"
    - "traefik.http.middlewares.app-reloj-https-redirect.redirectscheme.scheme=https"
    - "traefik.http.routers.app-reloj.middlewares=app-reloj-https-redirect"
    - "traefik.http.routers.app-reloj-secure.entrypoints=https"
    - "traefik.http.routers.app-reloj-secure.rule=Host(`reloj.byronrm.com`)"
    - "traefik.http.routers.app-reloj-secure.tls=true"
    - "traefik.http.routers.app-reloj-secure.tls.certresolver=http"
    - "traefik.http.routers.app-reloj-secure.service=app-reloj"
    - "traefik.http.services.app-reloj.loadbalancer.server.port=5000"
    - "traefik.docker.network=traefik-public"
```

networks:
traefik-public:
external: true
